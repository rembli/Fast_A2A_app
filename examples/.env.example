# Copy this file to examples/.env and fill in your values.
# python-dotenv walks up the directory tree, so a .env here is picked up
# by all example agents when they are started from their own subdirectory.

# Azure AI Foundry base URL — required for joke_agent, holiday_planner, image_creator.
# Host only, no path. The agents append /openai/v1 themselves.
AZURE_AI_BASE_URL=https://<resource-name>.services.ai.azure.com

# Deployment name as configured in Azure AI Foundry.
# joke_agent / holiday_planner default to gpt-4o, image_creator to gpt-image-1-mini.
AZURE_AI_DEPLOYMENT_NAME=

# Redis connection (all agents require a running Redis instance).
REDIS_URL=redis://localhost:6379

# Public URL of this service — used in the A2A agent card.
APP_BASE_URL=http://localhost:8000

# Show full exception details in agent failure messages (recommended in dev).
DEBUG=true
